# Optional build-time override for the shared relay server.
# If unset, the app uses the built-in default (see src/config.js):
#   https://barternet-relay.x7oracle-commits.deno.net   (Deno Deploy, WebSocket)
#
# Set this to point every build at your own Deno Deploy relay instead
# (https://<project>.<org>.deno.net). See DEPLOY-DENO.md.
# Copy to ".env" (or ".env.local") and rebuild.
VITE_RELAY_URL=https://barternet-relay.x7oracle-commits.deno.net
