# Optional build-time override for the shared relay server.
# If unset, the app uses the built-in default (see src/config.js):
#   https://barternet-relay.deno.dev   (Deno Deploy, WebSocket — scalable)
#
# Set this to point every build at your own relay instead. Works with:
#   • a Deno Deploy relay  (https://<name>.deno.dev)   — preferred, scalable
#   • a Node/Render relay  (https://<name>.onrender.com) — HTTP polling fallback
#   • a LAN address        (http://192.168.x.x:4000)     — same-WiFi testing
# Copy to ".env" (or ".env.local") and rebuild.
VITE_RELAY_URL=https://barternet-relay.deno.dev
